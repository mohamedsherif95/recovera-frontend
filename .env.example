VITE_API_BASE_URL=http://localhost:8080
VITE_APP_NAME=Recovera

# Google Tag Manager web container ID, for example GTM-XXXXXXX.
# Meta/Facebook Pixel should be configured inside GTM using the dataLayer events.
VITE_GTM_ID=

# Set to true locally to print dataLayer events in the browser console.
VITE_ANALYTICS_DEBUG=false
